{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account in the parish stock management system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string", "enum": ["Administrador", "Operador"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "pin", "role", "active", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log of actions performed in the system for transparency",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "action", "details", "timestamp"]
    },
    "Product": {
      "title": "Product",
      "description": "Item in stock, such as books, candles, wine, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "costPrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "minStock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "name", "category", "quantity", "costPrice", "minStock", "createdAt", "updatedAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Record of a parish checkout transaction sale row",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "salePrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" }
      },
      "required": ["id", "productId", "productName", "category", "quantity", "salePrice", "totalPrice", "sellerId", "sellerName", "timestamp"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Parish customer registers to hold contact logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "createdAt"]
    },
    "PurchaseLog": {
      "title": "PurchaseLog",
      "description": "Log of stock replenishment entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "category": { "type": "string" },
        "quantityAdded": { "type": "number" },
        "costPrice": { "type": "number" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "productName", "category", "quantityAdded", "costPrice", "buyerId", "buyerName", "timestamp"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Record of a parish operating expense/outgoing cash flow",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "category", "amount", "description", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users authorized in the system"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logging events for history"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product collection"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Parish product checkouts"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Known customer registry list"
    },
    "/purchase_logs/{purchaseId}": {
      "schema": "PurchaseLog",
      "description": "Stock inventory purchase logs history"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Parish operational expenses tracking data"
    }
  }
}
